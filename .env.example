# Required: Gateway authentication token (set in Railway service variables)
OPENCLAW_GATEWAY_TOKEN=your-secret-token-here

# Required: Anthropic API key for the AI model
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key (if using OpenAI models)
# OPENAI_API_KEY=sk-...

# Optional: Override the default OpenClaw version at build time
# OPENCLAW_VERSION=2026.3.23
